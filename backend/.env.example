# Database Configuration
# For local development with Supabase PostgreSQL
DATABASE_URL=jdbc:postgresql://your-supabase-instance.pooler.supabase.com:5432/postgres?sslmode=require
DATABASE_USER=your_database_user
DATABASE_PASSWORD=your_database_password

# Google OAuth2 Configuration
# Get credentials from https://console.cloud.google.com/
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Frontend Configuration
# URL where frontend is running (used for OAuth2 redirect)
FRONTEND_URL=http://localhost:5173

# Spoonacular API Configuration
# Get API key from https://spoonacular.com/food-api
SPOONACULAR_API_KEY=your_spoonacular_api_key

# JWT Configuration (optional - defaults provided in application.properties)
# JWT_SECRET=your_jwt_secret_key
# JWT_EXPIRATION=86400000
