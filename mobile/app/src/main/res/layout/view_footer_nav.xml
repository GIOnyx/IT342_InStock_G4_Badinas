<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/footerNavRoot"
    android:layout_width="match_parent"
    android:layout_height="84dp"
    android:background="@drawable/bg_footer_nav"
    android:gravity="center"
    android:orientation="horizontal"
    android:paddingStart="8dp"
    android:paddingEnd="8dp">

    <LinearLayout
        android:id="@+id/navSettings"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="6dp">

        <FrameLayout
            android:id="@+id/bubbleSettings"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@android:color/transparent">

            <ImageView
                android:id="@+id/iconSettings"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_web_settings" />
        </FrameLayout>

        <TextView
            android:id="@+id/labelSettings"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:text="@string/nav_settings"
            android:textSize="11sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/navRecipes"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="6dp">

        <FrameLayout
            android:id="@+id/bubbleRecipes"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@android:color/transparent">

            <ImageView
                android:id="@+id/iconRecipes"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_web_recipes" />
        </FrameLayout>

        <TextView
            android:id="@+id/labelRecipes"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:text="@string/nav_recipes"
            android:textSize="11sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/navPantry"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="4dp">

        <FrameLayout
            android:id="@+id/bubblePantry"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@android:color/transparent"
            android:foregroundGravity="center">

            <ImageView
                android:id="@+id/iconPantry"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_web_pantry"
                android:tint="@color/brand_text_muted" />
        </FrameLayout>

        <TextView
            android:id="@+id/labelPantry"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="@string/nav_pantry"
            android:textColor="@color/brand_text_muted"
            android:textSize="11sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/navFavorites"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="6dp">

        <FrameLayout
            android:id="@+id/bubbleFavorites"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@android:color/transparent">

            <ImageView
                android:id="@+id/iconFavorites"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_web_favorites" />
        </FrameLayout>

        <TextView
            android:id="@+id/labelFavorites"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:text="@string/nav_favorites"
            android:textSize="11sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/navProfile"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="6dp">

        <FrameLayout
            android:id="@+id/bubbleProfile"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@android:color/transparent">

            <ImageView
                android:id="@+id/iconProfile"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_web_profile" />
        </FrameLayout>

        <TextView
            android:id="@+id/labelProfile"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:text="@string/nav_profile"
            android:textSize="11sp" />
    </LinearLayout>

</LinearLayout>
