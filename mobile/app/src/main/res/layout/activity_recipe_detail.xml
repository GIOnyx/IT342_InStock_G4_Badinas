<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5"
    tools:context=".features.recipes.RecipeDetailActivity">

    <!-- Header Image -->
    <ImageView
        android:id="@+id/ivRecipeImage"
        android:layout_width="match_parent"
        android:layout_height="200dp"
        android:scaleType="centerCrop"
        android:background="#E0E0E0" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/tvRecipeTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                tools:text="Delicious Cake"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="#333333"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/tvRecipeReadyIn"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                tools:text="Ready in 45 minutes"
                android:textColor="#757575"
                android:layout_marginBottom="16dp" />

            <ProgressBar
                android:id="@+id/progressBar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:visibility="visible" />

            <LinearLayout
                android:id="@+id/detailContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone"
                tools:visibility="visible">

                <!-- Ingredients You Have -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ingredients You Have ✔️"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#4CAF50"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/tvUsedIngredients"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    tools:text="- Flour\n- Sugar"
                    android:lineSpacingExtra="4dp"
                    android:textColor="#333333" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#DDDDDD"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="16dp" />

                <!-- Missing Ingredients -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Missing Ingredients ❌"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#F44336"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/tvMissingIngredients"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    tools:text="- Milk\n- Eggs"
                    android:lineSpacingExtra="4dp"
                    android:textColor="#333333" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#DDDDDD"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="16dp" />

                <!-- Instructions -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Instructions"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#333333"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/tvInstructions"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    tools:text="1. Mix ingredients\\n2. Bake for 30 minutes"
                    android:lineSpacingExtra="4dp"
                    android:textColor="#555555" />

            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</LinearLayout>
